PORT=3000
MONGODB_URI=mongodb://localhost:27017/finance-tracker?replicaSet=rs0&directConnection=true
MAILERSEND_API_KEY=your-key-here
MAILERSEND_FROM_EMAIL=noreply@yourdomain.com
EMAIL_MONTHLY_QUOTA=3000
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173
WEBAUTHN_RP_NAME=Finance Tracker
COOKIE_SECURE=false
SESSION_TTL_DAYS=30

# --- Production overrides (docker-compose.prod.yml) ---
# COOKIE_SECURE=true            (set by compose)
# WEBAUTHN_RP_ID=finance.example.com
# WEBAUTHN_ORIGIN=https://finance.example.com
# CLOUDFLARE_TUNNEL_TOKEN=      (from Cloudflare Zero Trust dashboard)
